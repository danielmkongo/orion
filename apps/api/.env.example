NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ──────────────────────────────────────────────────
# MongoDB — choose ONE option:
#
# Option A: Local MongoDB (install from mongodb.com/try/download/community)
MONGODB_URI=mongodb://localhost:27017/orion
#
# Option B: MongoDB Atlas free tier (cloud.mongodb.com → free M0 cluster)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/orion
# ──────────────────────────────────────────────────

# Redis — OPTIONAL. Leave blank to skip (platform works without it).
# Install: https://github.com/tporadowski/redis/releases  (Windows)
# Or comment it out entirely:
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_REFRESH_SECRET=change-me-refresh-secret-also-very-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# CORS (URL of the frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Upload dirs
UPLOAD_DIR=./uploads
FIRMWARE_DIR=./firmware

# MQTT Broker — optional
# MQTT_BROKER_URL=mqtt://localhost:1883

INGESTION_SECRET=orion-ingestion-secret
FRONTEND_URL=http://localhost:5173
